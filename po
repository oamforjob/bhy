<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ใบเสนอราคา - B.H.Y การพิมพ์</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Prompt:wght@300;400;500;600&display=swap" rel="stylesheet">
    
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>

    <style>
        :root {
            --primary-blue: #003399;
            --soft-blue: #eef4ff;
            --light-grey: #f9f9f9;
            --placeholder-color: #cbd5e0;
            --success-green: #27ae60;
            --danger-red: #e74c3c;
            --save-orange: #f39c12;
        }

        * { box-sizing: border-box; }
        
        body { 
            font-family: 'Prompt', sans-serif; 
            background-color: #525659; 
            margin: 0; 
            padding: 10px; 
        }

        /* Toolbar จัดกลุ่มปุ่มให้สวยงาม */
        .no-print {
            max-width: 210mm;
            margin: 0 auto 10px;
            background: #2d3748;
            padding: 12px 25px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            color: white;
            border-radius: 12px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.2);
        }

        .toggle-group { display: flex; gap: 15px; align-items: center; }
        .action-group { display: flex; gap: 8px; }

        .btn { 
            padding: 8px 16px; 
            border: none; 
            border-radius: 8px; 
            cursor: pointer; 
            font-family: 'Prompt'; 
            font-weight: 500; 
            font-size: 14px;
            display: flex;
            align-items: center;
            gap: 5px;
            transition: 0.2s;
        }
        .btn-print { background: var(--success-green); color: white; }
        .btn-save-img { background: var(--save-orange); color: white; }
        .btn-clear { background: #4a5568; color: white; }
        
        .btn:hover { opacity: 0.9; transform: translateY(-1px); }
        .btn:disabled { background: #ccc; cursor: not-allowed; }

        .btn-add { background: var(--primary-blue); color: white; margin-top: 15px; }

        .mode-selector {
            display: inline-flex;
            background: #1a202c;
            padding: 4px;
            border-radius: 10px;
            cursor: pointer;
        }
        .opt { padding: 5px 15px; border-radius: 7px; font-size: 13px; color: #718096; }
        .opt.active { background: white; color: #1a202c; font-weight: 600; }

        /* การตั้งค่าหน้ากระดาษ */
        .page {
            width: 210mm;
            min-height: 297mm;
            padding: 15mm 20mm;
            margin: 0 auto;
            background: white;
            position: relative;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            box-shadow: 0 0 10px rgba(0,0,0,0.5);
        }

        /* Watermark */
        .watermark {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%) rotate(-45deg);
            font-size: 140px;
            color: rgba(0, 0, 0, 0.04);
            font-weight: 800;
            white-space: nowrap;
            pointer-events: none;
            display: none;
            z-index: 999;
            border: 15px solid rgba(0,0,0,0.02);
            padding: 20px;
        }
        .is-draft .watermark { display: block; }

        @media print {
            body { background: none; padding: 0; }
            .no-print { display: none !important; }
            .page { 
                margin: 0; 
                box-shadow: none; 
                width: 210mm; 
                height: 297mm; 
                padding: 10mm 15mm;
                -webkit-print-color-adjust: exact;
                print-color-adjust: exact;
            }
        }

        /* ส่วนหัวและข้อมูลร้าน */
        .header { 
            display: flex; 
            align-items: center; 
            border-bottom: 3px solid var(--primary-blue); 
            padding-bottom: 15px; 
            margin-bottom: 20px;
        }
        .logo-box { width: 110px; height: 110px; margin-right: 25px; display: flex; align-items: center; justify-content: center; }
        .logo-box img { max-width: 100%; max-height: 100%; object-fit: contain; }
        
        .shop-info { flex-grow: 1; line-height: 1.4; padding-right: 10px; }
        .shop-info h1 { margin: 0 0 5px 0; color: var(--primary-blue); font-size: 24px; }
        .shop-info p { margin: 0; font-size: 13.5px; color: #333; }

        .doc-title-area { 
            text-align: left; 
            width: 180px; 
            background: var(--light-grey);
            padding: 10px;
            border-radius: 4px;
        }
        .doc-title-area h2 { margin: 0 0 10px 0; color: var(--primary-blue); font-size: 24px; text-align: right; }
        .meta-row { display: flex; font-size: 13px; margin-bottom: 5px; }
        .meta-row b { min-width: 45px; }

        /* ข้อมูลลูกค้า */
        .customer-zone {
            display: grid;
            grid-template-columns: 1.5fr 1fr;
            gap: 20px;
            margin-bottom: 25px;
            padding: 15px 20px;
            background: var(--soft-blue);
            border-radius: 6px;
        }
        .cust-field { margin-bottom: 8px; font-size: 14px; display: flex; }
        .cust-field b { min-width: 75px; color: #333; }

        .editable-input { border-bottom: 1px dashed #cbd5e0; flex-grow: 1; outline: none; min-height: 22px; padding-left: 5px; }
        .editable-input:empty:before { content: attr(data-placeholder); color: var(--placeholder-color); }

        /* ตารางรายการ */
        table { width: 100%; border-collapse: collapse; }
        table th { background: var(--primary-blue); color: white; padding: 12px 8px; font-size: 14px; }
        table td { border-bottom: 1px solid #edf2f7; padding: 12px 8px; font-size: 14px; vertical-align: top; }
        #item-list tr:nth-child(even) { background-color: var(--light-grey); }
        
        .col-center { text-align: center; }
        .col-right { text-align: right; }
        .delete-row { color: var(--danger-red); cursor: pointer; font-weight: bold; }

        /* ส่วนสรุปเงิน */
        .summary-area { display: flex; justify-content: flex-end; margin-top: 20px; }
        .total-table { width: 340px; }
        .total-table td { padding: 6px 12px; border: none; }
        .grand-total { background: var(--primary-blue); font-weight: 600; color: white; font-size: 18px; }

        .vat-selector { display: inline-flex; background: #e2e8f0; padding: 3px; border-radius: 20px; cursor: pointer; margin-bottom: 5px; }
        .v-opt { padding: 2px 10px; border-radius: 15px; font-size: 11px; font-weight: 600; }
        .v-opt.active { background: var(--primary-blue); color: white; }

        /* เงื่อนไขแยกบรรทัด */
        .notes-box { margin-top: 20px; font-size: 13px; color: #4a5568; border: 1px solid #e2e8f0; padding: 15px; line-height: 1.8; background-color: var(--light-grey); border-radius: 6px; }

        /* ลายเซ็น */
        .signature-area { margin-top: auto; display: flex; justify-content: space-between; padding-top: 30px; text-align: center; }
        .sig-block { width: 45%; }
        .sig-line { border-bottom: 1px solid #333; margin: 30px auto 10px; width: 80%; }
        .sig-input { font-size: 14px; outline: none; border-bottom: 1px dashed #eee; min-width: 180px; display: inline-block; }
    </style>
</head>
<body onload="initApp()">

    <div class="no-print">
        <div class="toggle-group">
            <span style="font-size: 14px; font-weight: 500;">สถานะ:</span>
            <div class="mode-selector" onclick="toggleMode()">
                <div id="m_draft" class="opt active">แบบร่าง</div>
                <div id="m_final" class="opt">ฉบับจริง</div>
            </div>
        </div>
        <div class="action-group">
            <button id="btnSaveImg" class="btn btn-save-img" onclick="saveAsImage()"><span>บันทึกรูปภาพ</span></button>
            <button class="btn btn-print" onclick="window.print()"><span>พิมพ์ / PDF</span></button>
            <button class="btn btn-clear" onclick="clearHistory()"><span>รีเซ็ต</span></button>
        </div>
    </div>

    <div class="page is-draft" id="doc-page">
        <div class="watermark">ร่าง / DRAFT</div>

        <div class="header">
            <div class="logo-box">
                <img src="https://drive.google.com/thumbnail?id=14QglsWS86uC_r5ZWYLPbx9Vt7fDE7n5D&sz=w500" alt="B.H.Y Logo" onerror="this.src='https://via.placeholder.com/110?text=BHY+Logo'">
            </div>
            <div class="shop-info">
                <h1>B.H.Y การพิมพ์</h1>
                <p>1 บ้านดง หมู่ 7 ตำบลม่อนจอง อำเภออมก๋อย จังหวัดเชียงใหม่</p>
                <p>โทรศัพท์: 080-083-3590 , 092-281-8733</p>
                <p>Email: Bhyprinting@gmail.com</p>
            </div>
            <div class="doc-title-area">
                <h2>ใบเสนอราคา</h2>
                <div class="meta-row"><b>เลขที่:</b> <span class="editable-input" contenteditable="true" data-placeholder="......"></span></div>
                <div class="meta-row"><b>วันที่:</b> <span class="editable-input" contenteditable="true" data-placeholder="......"></span></div>
            </div>
        </div>

        <div class="customer-zone">
            <div>
                <div class="cust-field"><b>เรียน :</b> <div class="editable-input" id="c_name" contenteditable="true" oninput="saveH()">องค์การบริหารส่วนตำบลม่อนจอง</div></div>
                <div class="cust-field" style="margin-top: 5px;"><b>ที่อยู่ :</b> <div class="editable-input" id="c_addr" contenteditable="true" oninput="saveH()">99 ม.8 ตำบล ม่อนจอง อำเภออมก๋อย เชียงใหม่</div></div>
            </div>
            <div>
                <div class="cust-field"><b>เบอร์โทร :</b> <div class="editable-input" id="c_tel" contenteditable="true" oninput="saveH()">052 000 573</div></div>
                <div class="cust-field" style="margin-top: 5px;"><b>ผู้เสียภาษี :</b> <div class="editable-input" id="c_tax" contenteditable="true" oninput="saveH()">0994000433611</div></div>
            </div>
        </div>

        <table>
            <thead>
                <tr>
                    <th width="5%" class="no-print"></th>
                    <th width="8%">ลำดับ</th>
                    <th>รายการสินค้า / รายละเอียด</th>
                    <th width="12%">จำนวน</th>
                    <th width="15%">ราคา/หน่วย</th>
                    <th width="18%">ยอดรวม (บาท)</th>
                </tr>
            </thead>
            <tbody id="item-list">
                <tr>
                    <td class="no-print col-center"><span class="delete-row" onclick="removeRow(this)">×</span></td>
                    <td class="col-center">1</td>
                    <td contenteditable="true" class="editable-input" data-placeholder="รายละเอียดงานพิมพ์..."></td>
                    <td class="col-center qty" contenteditable="true" oninput="calc()">0</td>
                    <td class="col-right price" contenteditable="true" oninput="calc()">0.00</td>
                    <td class="col-right row-total">0.00</td>
                </tr>
            </tbody>
        </table>

        <button class="btn btn-add no-print" onclick="addRow()">+ เพิ่มแถวรายการใหม่</button>

        <div class="summary-area">
            <table class="total-table">
                <tr><td class="col-right">รวมเป็นเงิน:</td><td class="col-right" id="subt">0.00</td></tr>
                <tr>
                    <td class="col-right">
                        <div class="vat-selector no-print" onclick="toggleVat()">
                            <div id="v_off" class="v-opt active">ไม่คิดภาษี</div>
                            <div id="v_on" class="v-opt">ภาษี 7%</div>
                        </div>
                        <span id="vat-label">ภาษีมูลค่าเพิ่ม 0%:</span>
                    </td>
                    <td class="col-right" id="v_amt">0.00</td>
                </tr>
                <tr class="grand-total"><td class="col-right">ยอดรวมทั้งสิ้น:</td><td class="col-right" id="gtot">0.00</td></tr>
            </table>
        </div>

        <div class="notes-box">
            <b>เงื่อนไขและหมายเหตุ:</b><br>
            • กำหนดยืนราคา <span contenteditable="true">7</span> วัน<br>
            • กำหนดส่งมอบของ <span contenteditable="true">3-7</span> วัน หลังจากได้รับใบสั่งซื้อ (PO)<br>
            • กรณีสินค้าได้รับไม่ถูกต้อง ผู้ซื้อต้องแจ้งให้ทราบภายใน 7 วัน
        </div>

        <div class="signature-area">
            <div class="sig-block">
                <p>ผู้อนุมัติสั่งซื้อ</p>
                <div class="sig-line"></div>
                ( <div class="sig-input" contenteditable="true" data-placeholder="ชื่อ-นามสกุล"></div> )
                <p style="font-size: 12px; margin-top: 10px;">วันที่ ________/________/________</p>
            </div>
            <div class="sig-block">
                <p>ผู้เสนอราคา</p>
                <div class="sig-line"></div>
                ( <div class="sig-input" contenteditable="true">นางสาววิไลภรณ์ คำใจ</div> )
                <p style="font-size: 12px; margin-top: 5px; color: #666;">B.H.Y การพิมพ์</p>
            </div>
        </div>
    </div>

    <script>
        let isVatEnabled = false; 
        let isDraftMode = true;   

        function initApp() { loadH(); calc(); }

        function toggleMode() {
            isDraftMode = !isDraftMode;
            document.getElementById('m_draft').classList.toggle('active');
            document.getElementById('m_final').classList.toggle('active');
            const page = document.getElementById('doc-page');
            isDraftMode ? page.classList.add('is-draft') : page.classList.remove('is-draft');
        }

        function toggleVat() {
            isVatEnabled = !isVatEnabled;
            document.getElementById('v_on').classList.toggle('active');
            document.getElementById('v_off').classList.toggle('active');
            document.getElementById('vat-label').innerText = isVatEnabled ? "ภาษีมูลค่าเพิ่ม 7%:" : "ภาษีมูลค่าเพิ่ม 0%:";
            calc();
        }

        function addRow() {
            const tbody = document.getElementById('item-list');
            const rowCount = tbody.rows.length + 1;
            const tr = document.createElement('tr');
            tr.innerHTML = `
                <td class="no-print col-center"><span class="delete-row" onclick="removeRow(this)">×</span></td>
                <td class="col-center">${rowCount}</td>
                <td contenteditable="true" class="editable-input"></td>
                <td class="col-center qty" contenteditable="true" oninput="calc()">0</td>
                <td class="col-right price" contenteditable="true" oninput="calc()">0.00</td>
                <td class="col-right row-total">0.00</td>
            `;
            tbody.appendChild(tr);
            calc();
        }

        function removeRow(btn) { 
            btn.parentElement.parentElement.remove(); 
            document.querySelectorAll('#item-list tr').forEach((row, index) => {
                row.cells[1].innerText = index + 1;
            });
            calc(); 
        }

        function calc() {
            let total = 0;
            document.querySelectorAll('#item-list tr').forEach(row => {
                const q = parseFloat(row.querySelector('.qty').innerText.replace(/,/g, '')) || 0;
                const p = parseFloat(row.querySelector('.price').innerText.replace(/,/g, '')) || 0;
                const r = q * p; 
                total += r;
                row.querySelector('.row-total').innerText = r.toLocaleString('th-TH', {minimumFractionDigits: 2});
            });
            const vAmt = isVatEnabled ? total * 0.07 : 0;
            const grand = total + vAmt;
            document.getElementById('subt').innerText = total.toLocaleString('th-TH', {minimumFractionDigits: 2});
            document.getElementById('v_amt').innerText = vAmt.toLocaleString('th-TH', {minimumFractionDigits: 2});
            document.getElementById('gtot').innerText = grand.toLocaleString('th-TH', {minimumFractionDigits: 2});
        }

        // ฟังก์ชันบันทึกเป็นรูปภาพ
        function saveAsImage() {
            const page = document.getElementById('doc-page');
            const btn = document.getElementById('btnSaveImg');
            
            btn.disabled = true;
            btn.innerText = "กำลังสร้างรูป...";

            // ใช้ html2canvas แปลง div เป็น canvas
            html2canvas(page, {
                scale: 3, // เพิ่มความชัด 3 เท่า
                useCORS: true,
                logging: false,
                backgroundColor: "#ffffff"
            }).then(canvas => {
                const link = document.createElement('a');
                const date = new Date().toISOString().slice(0,10);
                link.download = `Quotation_BHY_${date}.png`;
                link.href = canvas.toDataURL('image/png');
                link.click();
                
                btn.disabled = false;
                btn.innerText = "บันทึกรูปภาพ";
            });
        }

        function saveH() {
            const d = { 
                n: document.getElementById('c_name').innerText, 
                a: document.getElementById('c_addr').innerText, 
                t: document.getElementById('c_tel').innerText, 
                x: document.getElementById('c_tax').innerText 
            };
            localStorage.setItem('bhy_v_final_upd', JSON.stringify(d));
        }

        function loadH() {
            const data = localStorage.getItem('bhy_v_final_upd');
            if (data) {
                const h = JSON.parse(data);
                if(h.n) document.getElementById('c_name').innerText = h.n;
                if(h.a) document.getElementById('c_addr').innerText = h.a;
                if(h.t) document.getElementById('c_tel').innerText = h.t;
                if(h.x) document.getElementById('c_tax').innerText = h.x;
            }
        }

        function clearHistory() { 
            if(confirm("ล้างข้อมูลทั้งหมด?")) { 
                localStorage.removeItem('bhy_v_final_upd'); 
                location.reload(); 
            } 
        }
    </script>
</body>
</html>
